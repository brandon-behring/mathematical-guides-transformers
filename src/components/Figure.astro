---
/**
 * Project-local Figure wrapper.
 *
 * It preserves the scaffold component's public API and themable inline-SVG
 * behavior while namespacing asset-internal IDs for the all-chapters print
 * document. Read failures and non-local assets retain the ordinary img path.
 */
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { assembleSvg, publicSvgPath } from '../lib/figure.mjs';

interface Props {
  src: string;
  caption?: string;
  width?: string;
  id?: string;
  alt?: string;
  desc?: string;
}

const { src, caption, width = '100%', id, alt, desc } = Astro.props;
const altText = alt ?? caption ?? '';
// Under the non-root base, authored srcs are base-prefixed (`/transformers/figures/…`)
// to satisfy the scaffold #190 check, but on disk they live at `public/figures/…`.
// publicSvgPath strips BASE_URL for the read (null when non-inlinable). The <img>
// fallback keeps the base-prefixed src, which is correct for the browser.
const diskPath = publicSvgPath(src, import.meta.env.BASE_URL);
// Derive the ID-namespacing key from the base-stripped path so the emitted keys
// stay identical whether or not the src carries the base prefix.
const figureKey = (id ?? `fig-${(diskPath ?? src).replace(/^\/+/, '').replace(/\.[^.]+$/, '')}`)
  .replace(/[^a-zA-Z0-9_-]/g, '-');
const captionId = caption ? `${figureKey}-caption` : undefined;

let inlineSvg: string | null = null;
if (diskPath) {
  try {
    const raw = readFileSync(join(process.cwd(), 'public', diskPath), 'utf8');
    inlineSvg = assembleSvg(raw, { caption, alt, desc, width, idBase: figureKey });
  } catch {
    inlineSvg = null;
  }
}
---

<figure class="figure" id={id} aria-labelledby={captionId}>
  {inlineSvg ? (
    <Fragment set:html={inlineSvg} />
  ) : (
    <img src={src} alt={altText} style={`width: ${width}; max-width: 100%;`} />
  )}
  {caption && <figcaption id={captionId}>{caption}</figcaption>}
</figure>

<style>
  /* Authored percentages tune desktop and print rhythm. On a phone they make
   * dense labels unnecessarily small, so diagrams use the available column. */
  @media (max-width: 42rem) {
    .figure :global(svg),
    .figure > img {
      width: 100% !important;
    }
  }
</style>
