---
interface Props {
  scope?: string;
}

const { scope = 'Local scope' } = Astro.props;
---

<aside class="notation-override" role="note" aria-label={`Notation override: ${scope}`}>
  <p class="notation-override__label">
    <span>Notation override</span>
    <span class="notation-override__scope">{scope}</span>
  </p>
  <div class="notation-override__body"><slot /></div>
</aside>

<style>
  .notation-override {
    margin-block: 1.25rem;
    padding: 0.8rem 1rem;
    border: 1px solid var(--color-border, #d1d5db);
    border-inline-start: 0.3rem solid var(--color-accent, #6d5bd0);
    border-radius: var(--radius-sm, 0.25rem);
    background: var(--color-bg-subtle, #f7f7fb);
    break-inside: avoid;
  }

  .notation-override__label {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.4rem 1rem;
    margin: 0 0 0.4rem;
    font-family: var(--font-sans, sans-serif);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .notation-override__scope {
    color: var(--color-text-muted, #6b7280);
    font-weight: 500;
    letter-spacing: normal;
    text-transform: none;
  }

  .notation-override__body :global(> :first-child) {
    margin-top: 0;
  }

  .notation-override__body :global(> :last-child) {
    margin-bottom: 0;
  }

  @media print {
    .notation-override {
      background: transparent;
      border-color: #777;
    }
  }
</style>
