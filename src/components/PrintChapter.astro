---
import { namespacePrintHeadingIds } from '../lib/print-html.mjs';

interface Props {
  prefix: string;
}

const { prefix } = Astro.props;
const rendered = await Astro.slots.render('default');
const namespaced = namespacePrintHeadingIds(rendered, prefix);
---

<section class="chapter-print">
  <Fragment set:html={namespaced} />
</section>
